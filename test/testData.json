  "endpoints": {
    "baseUrl": "http://localhost:5000",
    "auth": {
      "register": "POST /api/auth/register",
      "completeRegistration": "POST /api/auth/complete-registration",
      "login": "POST /api/auth/login",
      "verifyLoginOtp": "POST /api/auth/verify-login-otp",
      "resendLoginOtp": "POST /api/auth/resend-login-otp",
      "getUser": "GET /api/auth/user/:id",
      "updateUser": "PUT /api/auth/updateInfo/:id",
      "changePassword": "PUT /api/auth/change-password/:id"
    },
    "store": {
      "createStore": "POST /api/store/createStore (multipart: field image optional)",
      "getStore": "GET /api/store/:id",
      "updateStore": "PUT /api/store/:id",
      "createStaff": "POST /api/store/staff",
      "getStaff": "GET /api/store/staff/:storeId",
      "updateStaff": "PUT /api/store/staff/:id",
      "deleteStaff": "DELETE /api/store/staff/:id",
      "createAnalytics": "POST /api/store/analytics",
      "getAnalytics": "GET /api/store/analytics/:storeId",
      "createRegion": "POST /api/store/region",
      "getRegion": "GET /api/store/region/:storeId",
      "updateRegion": "PUT /api/store/region/:id"
    },
    "product": {
      "addProduct": "POST /api/product/add",
      "bulkUpload": "POST /api/product/bulk",
      "bulkUploadFile": "POST /api/product/bulk/upload (multipart field: file)",
      "getByUser": "GET /api/product/user/:userId",
      "getOne": "GET /api/product/:id",
      "update": "PUT /api/product/:id"
    }
  },
  "notes": {
    "userId": "Use numeric ids from your DB after register + complete-registration (GET /api/auth/user/:id).",
    "storeId": "Use store id from createStore response or GET /api/store/:id.",
    "productUserId": "All product routes use userId (owner), not storeId.",
    "bulkUpload": "Send JSON body { userId, products: [...] } or upload test/bulkUploadProducts.json via POST /api/product/bulk/upload (multipart field: file). Replace userId with your DB id. Each product needs name (or legacy field product). Optional: description, category, price, stock, sku, barcode, status, variants, image.",
    "createStoreImage": "For file upload use form-data with field name image; JSON body fields go in the same request.",
    "otp": "Login OTP is emailed; use tempToken + otp from login flow for verify-login-otp.",
    "token": "completeRegistration.token must match emailVerifyCode after verify-email."
  }
